# ─────────────────────────────────────────────────────────────────────────────
# LLM Configuration (required)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4
OPENAI_MODEL_MINI=gpt-5.4-mini

# ─────────────────────────────────────────────────────────────────────────────
# Harvest API (required for n2/n3 profile enrichment)
# ─────────────────────────────────────────────────────────────────────────────
HARVEST_API_KEY=your_harvest_api_key

# ─────────────────────────────────────────────────────────────────────────────
# Search — vendor.search (optional but strongly recommended)
# ─────────────────────────────────────────────────────────────────────────────
# Exa.ai — Company Search + semantic retrieval (highly recommended)
# Powers: RIConnector.resolve_ri_url(), SearchOrchestrator, StrategyRetriever
# See: https://exa.ai/blog/company-search-benchmarks
EXA_API_KEY=your_exa_api_key

# SearXNG — self-hosted web search (optional fallback)
# Docker: docker run -p 8080:8080 searxng/searxng
SEARXNG_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────────────────────────
# Scraper — vendor.scraper (optional enhanced adapters)
# ─────────────────────────────────────────────────────────────────────────────
# Browserless — for JS-heavy RI pages (optional)
BROWSERLESS_ENDPOINT=http://localhost:3000
BROWSERLESS_TOKEN=your_browserless_token

# Jina Reader API — enhanced HTML extraction (optional, improve quality)
JINA_API_KEY=your_jina_api_key

# ─────────────────────────────────────────────────────────────────────────────
# CVM (public API, no key required)
# ─────────────────────────────────────────────────────────────────────────────
CVM_API_BASE_URL=https://dados.cvm.gov.br
