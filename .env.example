# peopledd Runtime Configuration
# Copy to .env and customize, or set these as Railway environment variables

# === API Server ===
PORT=8000
HOST=0.0.0.0
PEOPLEDD_OUTPUT_DIR=/tmp/peopledd_runs

# === Core LLM (Required for semantic fusion, strategy, market pulse) ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_MINI=gpt-4o-mini
OPENAI_MARKET_PULSE_MODEL=gpt-4o-mini

# === Search & Discovery ===
EXA_API_KEY=...
SEARXNG_URL=http://localhost:8888  # Optional SearXNG instance
SERPER_API_KEY=...                  # Optional Serper (Google search backend)

# === Data Enrichment ===
HARVEST_API_KEY=...                 # LinkedIn-like people search
JINA_API_KEY=...                    # Content extraction

# === Web Scraping & Rendering ===
BROWSERLESS_ENDPOINT=ws://localhost:3000  # Browserless for JS rendering
BROWSERLESS_TOKEN=...

# === Market Pulse / Alternative LLM ===
PERPLEXITY_API_KEY=...              # Optional Sonar briefings

# === Notes for Railway ===
# 1. Set PEOPLEDD_OUTPUT_DIR=/app/runs (persisted volume)
# 2. Mount volume at /app/runs to retain artifacts across restarts
# 3. Keep OPENAI_API_KEY and other secrets as Railway Protected Variables
# 4. For development, uncomment and set locally; Railway console overrides
